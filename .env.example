# ---- Telegram credentials (required) ----
# Obtain api_id / api_hash from https://my.telegram.org -> API development tools.
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
# Bot token from @BotFather.
BOT_TOKEN=

# ---- Access control (optional) ----
# Space/comma separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone.
ALLOWED_USER_IDS=

# ---- Filesystem ----
# Root working directory for downloads and temp assets.
WORK_DIR=./downloads

# ---- aria2c JSON-RPC ----
# If pointing at localhost and no daemon is running, the bot spawns one.
ARIA2_HOST=http://localhost
ARIA2_PORT=6800
ARIA2_SECRET=

# ---- FFmpeg binaries (override if not on PATH) ----
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# ---- Tuning ----
# Seconds between progress message edits (Telegram rate-limit friendly).
PROGRESS_INTERVAL=5
# Internal upload worker hint.
UPLOAD_WORKERS=4
# Max simultaneous end-to-end tasks.
MAX_CONCURRENT_TASKS=3
